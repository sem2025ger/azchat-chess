PORT=4000

# CORS Setting: Set this to your Vercel URL (e.g. https://aztr-chess.vercel.app)
CLIENT_URL=http://localhost:5173

# Supabase Connection (Authoritative)
SUPABASE_URL=https://your-project-id.supabase.co
# IMPORTANT: Use service_role key here, not anon key
SUPABASE_SERVICE_KEY=your-service-role-secret-key
